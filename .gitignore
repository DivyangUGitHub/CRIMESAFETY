# Create .gitignore with more exclusions
@'
# Dependencies
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js build output
.next/
out/
build/
dist/
.vercel/
vercel.json

# Environment files
.env
.env.local
.env*.local
.env.production
.env.development
.env.test

# Logs
*.log
logs/
*.log

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Prisma
prisma/*.db
prisma/*.db-journal
prisma/migrations/*.db
prisma/seed.js.map

# Uploads
uploads/
public/uploads/
temp/
tmp/

# Certificates & Keys
*.pem
*.p12
*.key
*.crt
*.csr
cert.pem
*.p8

# Debug files
*.pid
*.seed
*.pid.lock

# Typescript
*.tsbuildinfo

# Testing
coverage/
.nyc_output/

# Turborepo
.turbo

# Local Netlify folder
.netlify/

# Stackbit
.stackbit

# Vercel
.vercel
vercel.json
.vercel/output/

# Dotenv
.env.development.local
.env.test.local
.env.production.local

# Misc
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip
*.sql
*.sqlite
.DS_Store
AppleDouble
.LSOverride
Icon

# Ignore all .log files
*.log

# Ignore all .tmp files
*.tmp

# Backend compiled files
Backend/dist/
Backend/build/
Backend/*.js.map

# Package manager locks (keep package-lock.json but commit it)
# package-lock.json - DO NOT ignore this!
'@ | Out-File -FilePath ".gitignore" -Encoding UTF8