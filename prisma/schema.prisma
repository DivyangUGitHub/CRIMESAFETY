generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String   @unique
  emailVerified DateTime?
  password  String?
  phone     String?
  location  String?
  role      String   @default("USER")
  image     String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  reports       Report[]
  chatMessages  ChatMessage[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  emailVerifications EmailVerification[]
  notificationSettings NotificationSettings?
  comments Comment[]
  sessions Session[]
  accounts Account[]
  passwordResets PasswordReset[]
}

model Report {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  category      String
  status        String    @default("PENDING")
  severity      String    @default("MEDIUM")
  latitude      Float?
  longitude     Float?
  address       String?
  date          DateTime
  images        String[]
  userId        String    @db.ObjectId
  isAnonymous   Boolean   @default(false)
  aiVerified    Boolean   @default(false)
  aiConfidence  Float?
  aiAnalysis    String?
  viewCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiAnalysisLogs AIAnalysisLog[]
  updates ReportUpdate[]
  comments Comment[]
}

model ChatMessage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  userId      String   @db.ObjectId
  isAI        Boolean  @default(false)
  sessionId   String
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  title       String
  message     String
  type        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ✅ Activity Log Model
model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ✅ Email Verification Model
model EmailVerification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([code])
  @@map("email_verifications")
}

// ✅ AI Analysis Log Model (No @db.Text)
model AIAnalysisLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  reportId    String?  @db.ObjectId
  reportData  String?
  analysisResult String?
  confidence  Float?
  severity    String?
  createdAt   DateTime @default(now())
  
  report Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  
  @@index([createdAt])
  @@map("ai_analysis_logs")
}

// ✅ Police Station Model
model PoliceStation {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String   @unique
  email      String?
  phone      String?
  latitude   Float?
  longitude  Float?
  address    String?
  jurisdiction String?
  createdAt  DateTime @default(now())
  
  @@index([latitude, longitude])
  @@map("police_stations")
}

// ✅ Report Update Model
model ReportUpdate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  reportId    String   @db.ObjectId
  message     String
  type        String
  createdAt   DateTime @default(now())
  
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  
  @@index([reportId])
  @@index([createdAt])
  @@map("report_updates")
}

// ✅ Notification Settings Model
model NotificationSettings {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @unique @db.ObjectId
  emailNotifications Boolean @default(true)
  pushNotifications Boolean @default(true)
  reportUpdates     Boolean @default(true)
  safetyAlerts      Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notification_settings")
}

// ✅ Comment Model (No @db.Text)
model Comment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  reportId    String   @db.ObjectId
  userId      String   @db.ObjectId
  likes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([reportId])
  @@index([createdAt])
  @@map("comments")
}

// ✅ Session Model
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  createdAt    DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

// ✅ Account Model
model Account {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// ✅ Verification Token Model (Fixed - MongoDB needs @id)
model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ContactMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([createdAt])
  @@map("contact_messages")
}

model PasswordReset {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}